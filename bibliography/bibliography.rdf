        <link:link rdf:resource="#item_375"/>
        <dc:subject>
           <z:AutomaticTag><rdf:value>bee visitation</rdf:value></z:AutomaticTag>
        </dc:subject>
        <dc:subject>
            <z:AutomaticTag>
               <rdf:value>bees pollination</rdf:value>
            </z:AutomaticTag>
        </dc:subject>
        <dc:subject>
           <z:AutomaticTag><rdf:value>challenges</rdf:value></z:AutomaticTag>
