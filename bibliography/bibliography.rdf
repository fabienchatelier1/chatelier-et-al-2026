            <dcterms:URI>
               <rdf:value>https://doi.org/10.1007/3-540-26590-2_3</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2025-02-05 18:47:29</dcterms:dateSubmitted>
        <bib:pages>13-18</bib:pages>
    </bib:BookSection>
