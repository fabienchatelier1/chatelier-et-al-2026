        <dc:subject>
           <z:AutomaticTag><rdf:value>Biodiversity</rdf:value></z:AutomaticTag>
        </dc:subject>
        <dc:subject>
           <z:AutomaticTag><rdf:value>Arabian Gulf</rdf:value></z:AutomaticTag>
        </dc:subject>
