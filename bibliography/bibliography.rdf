        <dc:subject>
            <z:AutomaticTag>
               <rdf:value>Bibliometric mapping</rdf:value>
            </z:AutomaticTag>
        </dc:subject>
        <dc:subject>
            <z:AutomaticTag>
               <rdf:value>Journal co-citation analysis</rdf:value>
            </z:AutomaticTag>
