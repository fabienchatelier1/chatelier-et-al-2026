        <dc:subject>
            <z:AutomaticTag>
               <rdf:value>Agrobiodiversity conservation</rdf:value>
            </z:AutomaticTag>
        </dc:subject>
        <dc:subject>
            <z:AutomaticTag>
               <rdf:value>Climate-resilience</rdf:value>
            </z:AutomaticTag>
        </dc:subject>
        <dc:subject>
            <z:AutomaticTag>
               <rdf:value>Green Infrastructure (GI)</rdf:value>
            </z:AutomaticTag>
        </dc:subject>
